---
import type { Translations } from '../i18n';
import IconMail from './icons/IconMail.astro';
import IconLinkedIn from './icons/IconLinkedIn.astro';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const email = 'mateusz.gorniak@gmail.com';
const linkedin = 'https://www.linkedin.com/in/mateusz-g%C3%B3rniak/';
---

<section class="section" id="contact">
  <div class="container reveal">
    <p class="section-label" data-i18n="contact.label">{t.contact.label}</p>
    <h2 class="section-title" data-i18n="contact.title">{t.contact.title}</h2>
    <p class="section-lead" data-i18n="contact.lead">{t.contact.lead}</p>

    <div class="glass-card contact-panel">
      <form
        class="contact-form"
        id="contact-form"
        data-recipient={email}
      >
        <div class="form-group">
          <label class="form-label" for="name" data-i18n="contact.name">{t.contact.name}</label>
          <input class="form-input" type="text" id="name" name="name" required autocomplete="name" />
        </div>

        <div class="form-group">
          <label class="form-label" for="email" data-i18n="contact.email">{t.contact.email}</label>
          <input class="form-input" type="email" id="email" name="email" required autocomplete="email" />
        </div>

        <div class="form-group">
          <label class="form-label" for="message" data-i18n="contact.message">{t.contact.message}</label>
          <textarea class="form-textarea" id="message" name="message" required></textarea>
        </div>

        <button type="submit" class="btn" id="contact-submit" data-i18n="contact.submit">
          {t.contact.submit}
        </button>

        <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
      </form>

      <div class="contact-direct">
        <p class="contact-or" data-i18n="contact.or">{t.contact.or}</p>
        <ul class="contact-links">
          <li>
            <a href={`mailto:${email}`} class="contact-channel">
              <span class="contact-channel-icon" aria-hidden="true">
                <IconMail />
              </span>
              <span class="contact-channel-text">
                <span class="contact-channel-label" data-i18n="contact.emailLabel">{t.contact.emailLabel}</span>
                <span class="contact-channel-value">{email}</span>
              </span>
            </a>
          </li>
          <li>
            <a href={linkedin} class="contact-channel" target="_blank" rel="noopener noreferrer">
              <span class="contact-channel-icon" aria-hidden="true">
                <IconLinkedIn />
              </span>
              <span class="contact-channel-text">
                <span class="contact-channel-label" data-i18n="contact.linkedin">{t.contact.linkedin}</span>
                <span class="contact-channel-value" data-i18n="contact.linkedinHint">{t.contact.linkedinHint}</span>
              </span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-panel {
    max-width: 640px;
    padding: 2rem;
  }

  .contact-form {
    position: relative;
  }

  .contact-direct {
    margin-top: 2rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--section-divider);
  }

  .contact-or {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--nav-muted);
    margin-bottom: 1rem;
    text-align: center;
  }

  .contact-links {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.625rem;
  }

  .contact-channel {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.45);
    color: var(--text);
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .contact-channel:hover {
    opacity: 1;
    border-color: var(--border-hover);
    background: rgba(255, 255, 255, 0.85);
  }

  .contact-channel-icon {
    display: inline-flex;
    flex-shrink: 0;
    margin-top: 0.125rem;
    color: var(--nav-muted);
  }

  .contact-channel-icon :global(.icon) {
    width: 1.25rem;
    height: 1.25rem;
  }

  .contact-channel-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .contact-channel-label {
    font-family: var(--font-nav);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--nav-ink);
    line-height: 1.2;
  }

  .contact-channel-value {
    font-size: 0.8125rem;
    color: var(--nav-muted);
    line-height: 1.35;
    word-break: break-word;
  }

  @media (max-width: 540px) {
    .contact-panel {
      padding: 1.5rem;
    }

    .contact-links {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');

  function getMessage(key: string): string {
    const locale = localStorage.getItem('locale') ?? 'en';
    const data = (window as Window & { __i18n?: Record<string, Record<string, unknown>> }).__i18n;
    if (!data?.[locale]) return key;

    const parts = key.split('.');
    let value: unknown = data[locale];
    for (const part of parts) {
      value = (value as Record<string, unknown>)?.[part];
    }
    return typeof value === 'string' ? value : key;
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const recipient = form.dataset.recipient;
    if (!recipient) return;

    const formData = new FormData(form);
    const name = formData.get('name')?.toString().trim() ?? '';
    const senderEmail = formData.get('email')?.toString().trim() ?? '';
    const message = formData.get('message')?.toString().trim() ?? '';

    const subject = getMessage('contact.mailSubject').replace('{name}', name);
    const body = [
      `${getMessage('contact.name')}: ${name}`,
      `${getMessage('contact.email')}: ${senderEmail}`,
      '',
      message,
    ].join('\n');

    window.location.href = `mailto:${recipient}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

    if (status) {
      status.textContent = getMessage('contact.mailHint');
      status.className = 'form-status';
    }
  });
</script>
