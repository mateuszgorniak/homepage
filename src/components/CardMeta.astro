---
import IconAudience from './icons/IconAudience.astro';
import IconSituation from './icons/IconSituation.astro';

interface Props {
  value: string;
  label: string;
  variant: 'audience' | 'situation';
}

const { value, label, variant } = Astro.props;
const Icon = variant === 'audience' ? IconAudience : IconSituation;
---

<p class:list={['card-meta', `card-meta--${variant}`]} aria-label={`${label}: ${value}`}>
  <span class="card-meta-icon">
    <Icon />
  </span>
  <span class="card-meta-value">{value}</span>
</p>
