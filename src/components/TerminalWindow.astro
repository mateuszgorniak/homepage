---
interface Props {
  title: string;
  titleI18n?: string;
  bodyClass?: string;
  class?: string;
}

const { title, titleI18n, bodyClass = '', class: className = '' } = Astro.props;
---

<div class:list={['terminal-window', className]}>
  <div class="terminal-titlebar">
    <div class="terminal-traffic" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <span class="terminal-title" data-i18n={titleI18n}>{title}</span>
  </div>
  <div class:list={['terminal-body', bodyClass]}>
    <slot />
  </div>
</div>
