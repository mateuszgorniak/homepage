---
import type { Translations } from '../i18n';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section class="section" id="process">
  <div class="container reveal">
    <p class="section-label">{t.nav.process}</p>
    <h2 class="section-title">{t.howIWork.title}</h2>
    <p class="section-lead">{t.howIWork.lead}</p>

    <div class="timeline">
      {t.howIWork.steps.map((step, i) => (
        <div class="timeline-item">
          <div class="timeline-number">{i + 1}</div>
          <div>
            <h3 class="timeline-title">{step.title}</h3>
            <p class="timeline-text">{step.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
