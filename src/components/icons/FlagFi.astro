---
interface Props {
  class?: string;
}

const { class: className = 'icon-flag' } = Astro.props;
---

<svg class={className} viewBox="0 0 20 14" aria-hidden="true">
  <rect width="20" height="14" rx="2" fill="#fff"></rect>
  <rect x="6" width="3.5" height="14" fill="#003580"></rect>
  <rect y="5.25" width="20" height="3.5" fill="#003580"></rect>
</svg>
