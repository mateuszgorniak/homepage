  <path d="M12 4.5 19 8v8l-7 3.5L5 16V8z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
  <circle cx="12" cy="12" r="2" stroke="currentColor" stroke-width="1.75"/>
</svg>

<style>
