---
import RubyconLogo from './RubyconLogo.astro';
import type { Locale, Translations } from '../i18n';
import { BUSINESS_ID, YTJ_URL } from '../config/site';
import { getPrivacyPath } from '../lib/locale-urls';

interface Props {
  t: Translations;
  locale: Locale;
}

const { t, locale } = Astro.props;
const privacyPath = getPrivacyPath(locale, import.meta.env.BASE_URL);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-meta reveal">
      <p class="footer-brand">
        <RubyconLogo class="footer-logo-mark" />
        <span>rubycon</span>
      </p>
      <p class="footer-form">{t.footer.form}</p>
      <p class="footer-languages">{t.footer.languages}</p>
      <p class="footer-business">
        <span>{t.footer.businessId}</span>: {BUSINESS_ID}
        {' · '}
        <a href={YTJ_URL} target="_blank" rel="noopener noreferrer">
          {t.footer.ytjLink}
        </a>
      </p>
      <p class="footer-legal">
        <a href={privacyPath}>{t.privacy.title}</a>
      </p>
      <p class="footer-copy">
        © {year} Mateusz Górniak. <span>{t.footer.rights}</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 4rem 0 2.5rem;
    background: var(--section-band);
    border-top: 1px solid var(--section-divider);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .footer-brand :global(.footer-logo-mark) {
    display: inline-flex;
    width: 1.25rem;
    height: 1.25rem;
  }

  .footer-brand :global(.footer-logo-mark svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .footer-form,
  .footer-languages,
  .footer-business,
  .footer-legal,
  .footer-copy {
    font-size: 0.8125rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .footer-business a,
  .footer-legal a {
    font-size: inherit;
  }
</style>
