---
import IconMail from './icons/IconMail.astro';
import IconLinkedIn from './icons/IconLinkedIn.astro';
import RubyconLogo from './RubyconLogo.astro';
import type { Translations } from '../i18n';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const ytjUrl = 'https://tietopalvelu.ytj.fi/yritys/3597173-9';
const email = 'mateusz.gorniak@gmail.com';
const linkedin = 'https://www.linkedin.com/in/mateusz-g%C3%B3rniak/';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-social reveal">
      <a href={`mailto:${email}`} class="footer-social-link">
        <IconMail />
        <span>{email}</span>
      </a>
      <a href={linkedin} class="footer-social-link" target="_blank" rel="noopener noreferrer">
        <IconLinkedIn />
        <span data-i18n="contact.linkedin">{t.contact.linkedin}</span>
      </a>
    </div>

    <div class="footer-meta reveal">
      <p class="footer-brand">
        <RubyconLogo class="footer-logo-mark" />
        <span>rubycon</span>
      </p>
      <p class="footer-form" data-i18n="footer.form">{t.footer.form}</p>
      <p class="footer-business">
        <span data-i18n="footer.businessId">{t.footer.businessId}</span>:{' '}
        <span data-i18n="footer.businessIdValue">{t.footer.businessIdValue}</span>
        {' · '}
        <a href={ytjUrl} target="_blank" rel="noopener noreferrer" data-i18n="footer.ytjLink">
          {t.footer.ytjLink}
        </a>
      </p>
      <p class="footer-copy">
        © {year} Mateusz Górniak. <span data-i18n="footer.rights">{t.footer.rights}</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 4rem 0 2.5rem;
    background: var(--section-band);
    border-top: 1px solid var(--section-divider);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
  }

  .footer-social {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem 1rem;
  }

  .footer-social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    font-size: 0.875rem;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .footer-social-link:hover {
    color: var(--text);
    border-color: var(--border-hover);
    background: var(--surface-hover);
    opacity: 1;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .footer-brand :global(.footer-logo-mark) {
    display: inline-flex;
    width: 1.25rem;
    height: 1.25rem;
  }

  .footer-brand :global(.footer-logo-mark svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .footer-form,
  .footer-business,
  .footer-copy {
    font-size: 0.8125rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .footer-business a {
    font-size: inherit;
  }
</style>
