---
import type { Translations } from '../i18n';
import IconUsers from './icons/IconUsers.astro';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section class="section" id="services">
  <div class="container reveal">
    <p class="section-label">{t.nav.services}</p>
    <h2 class="section-title">{t.services.title}</h2>
    <p class="section-lead">{t.services.lead}</p>

    <div class="grid-2">
      {t.services.items.map((item) => (
        <article class="glass-card service-card">
          <h3 class="service-title">{item.title}</h3>
          <div class="service-fit">
            <span class="service-fit-icon" aria-hidden="true">
              <IconUsers />
            </span>
            <div class="service-fit-text">
              <span class="service-fit-label">{t.services.bestForLabel}</span>
              <span class="service-fit-value">{item.bestFor}</span>
            </div>
          </div>
          <p class="service-summary">{item.summary}</p>
          <ul class="service-points">
            {item.points.map((point) => (
              <li class="service-point-item">
                <details class="service-point">
                  <summary class="service-point-summary">{point.title}</summary>
                  <div class="service-point-body">
                    <div class="service-point-inner">
                      <p class="service-point-detail">{point.detail}</p>
                    </div>
                  </div>
                </details>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .service-card {
    padding: 1.75rem;
  }

  .service-card:hover {
    transform: none;
  }

  .service-title {
    font-family: var(--font-nav);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .service-fit {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    margin-bottom: 0.875rem;
    padding-left: 0.75rem;
    border-left: 2px solid var(--accent);
  }

  .service-fit-icon {
    display: inline-flex;
    flex-shrink: 0;
    margin-top: 0.125rem;
    color: var(--accent);
  }

  .service-fit-icon :global(svg) {
    width: 1rem;
    height: 1rem;
    display: block;
  }

  .service-fit-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .service-fit-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 1.3;
  }

  .service-fit-value {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.45;
  }

  .service-summary {
    font-size: 0.9375rem;
    color: var(--muted);
    margin-bottom: 1.25rem;
  }

  .service-points {
    list-style: none;
    display: grid;
    gap: 0.5rem;
  }

  .service-point-item {
    margin: 0;
  }

  .service-point {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--tag-bg);
    overflow: hidden;
    transition:
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .service-point[open] {
    border-color: var(--border-hover);
    background: var(--surface);
  }

  .service-point-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .service-point-summary::-webkit-details-marker {
    display: none;
  }

  .service-point-summary::after {
    content: '+';
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--accent);
    line-height: 1;
    transition: transform 0.25s ease;
  }

  .service-point[open] .service-point-summary::after {
    content: '−';
  }

  .service-point-summary:hover {
    color: var(--nav-ink);
  }

  .service-point-body {
    height: 0;
    overflow: hidden;
  }

  .service-point[open] .service-point-body {
    height: auto;
  }

  .service-point-inner {
    padding: 0 0.75rem 0.75rem;
  }

  .service-point-detail {
    font-size: 0.8125rem;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .service-point-body {
      height: auto;
      overflow: visible;
    }

    .service-point:not([open]) .service-point-body {
      display: none;
    }
  }
</style>

<script>
  import { initServiceAccordions } from '../scripts/service-accordions';

  initServiceAccordions();
</script>
