---
import '../styles/global.css';
import '../styles/window-ui.css';
import '../styles/icons.css';
import SiteNav from '../components/SiteNav.astro';
import type { Locale } from '../i18n';
import { defaultLocale, getTranslations } from '../i18n';

interface Props {
  locale?: Locale;
  title?: string;
  description?: string;
}

const locale = Astro.props.locale ?? defaultLocale;
const t = getTranslations(locale);
const title = Astro.props.title ?? t.meta.title;
const description = Astro.props.description ?? t.meta.description;
const siteUrl = Astro.site?.href ?? 'https://mateusz-gorniak.github.io/rubycon-homepage/';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&family=Space+Grotesk:wght@500;600&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ProfessionalService',
      name: 'RubyCon',
      description,
      url: siteUrl,
      email: 'mateusz.gorniak@gmail.com',
      founder: {
        '@type': 'Person',
        name: 'Mateusz Górniak',
        jobTitle: 'Backend Developer & Fractional CTO',
        sameAs: 'https://www.linkedin.com/in/mateusz-g%C3%B3rniak/',
      },
      identifier: {
        '@type': 'PropertyValue',
        name: 'Y-tunnus',
        value: '3597173-9',
      },
    })} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <div class="page-wrapper">
      <SiteNav t={t} />
      <main id="main">
        <slot />
      </main>
    </div>
  </body>
</html>
