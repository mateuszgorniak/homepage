{
  "name": "rubycon-homepage",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "dev:docker": "ASTRO_TELEMETRY_DISABLED=1 astro dev --host 0.0.0.0 --port 4321",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "build": "npm run generate:sitemap && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "preview:docker": "ASTRO_TELEMETRY_DISABLED=1 astro preview --host 0.0.0.0 --port 4321"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "astro": "^7.0.4"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
